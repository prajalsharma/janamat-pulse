# ── SolVane backend configuration ──────────────────────────────────────────
# Copy to `.env` and fill in. The agent runs fully in DRY_RUN with no keys set.

# Server
PORT=4000
LOG_LEVEL=info

# ── AI sentiment engine ─────────────────────────────────────────────────────
# If ANTHROPIC_API_KEY is set, headlines are scored by Claude. Otherwise the
# agent falls back to a deterministic lexical analyzer so it still runs live.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# ── Solana ──────────────────────────────────────────────────────────────────
# RPC endpoint. Defaults to public mainnet; use a Helius/QuickNode URL in prod.
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_CLUSTER=mainnet-beta

# Secret key for the agent's trading wallet. Accepts either a base58 string or a
# JSON byte-array (Solana CLI format). Leave blank and the agent auto-generates a
# real Keypair on first boot, persisting it to data/agent-wallet.json (never
# overwritten) and reloading it every subsequent boot — so the agent ALWAYS has a
# real address. On devnet you can then fund it via POST /api/wallet/airdrop.
AGENT_WALLET_SECRET=

# Jupiter Swap API base. Default is the keyless free tier. Set to
# https://api.jup.ag if you hold a paid Jupiter API key (higher rate limits).
JUP_API_BASE=https://lite-api.jup.ag

# ── Execution mode ──────────────────────────────────────────────────────────
# dry-run  : decisions + Jupiter quotes are fetched, NO transaction is sent.
# live     : real swaps are broadcast (requires a funded AGENT_WALLET_SECRET).
EXECUTION_MODE=dry-run

# ── Trading policy ──────────────────────────────────────────────────────────
# Quote/target tokens (mainnet mints).
QUOTE_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
BASE_MINT=So11111111111111111111111111111111111111112

# Risk controls
MAX_TRADE_USD=50
MIN_SENTIMENT_CONFIDENCE=0.6
MIN_PRICE_MOVE_PCT=1.0
TRADE_COOLDOWN_SECONDS=120
MAX_SLIPPAGE_BPS=100

# Agent loop cadence (how often to poll news + decide), in seconds
AGENT_TICK_SECONDS=45

# Price mode. sentiment = demo price that drifts with the latest news sentiment
# (default, works without AI): good news trends up, bad news down, over time.
# live = real spot price from Jupiter/Pyth. Forced to live when EXECUTION_MODE=live
# so real trades never size off a simulated price.
PRICE_MODE=sentiment
PRICE_MAX_DRIFT_PCT=0.8

# News sources (comma-separated RSS URLs). These defaults are free + keyless.
NEWS_FEEDS=https://cointelegraph.com/rss/tag/solana,https://decrypt.co/feed,https://cryptoslate.com/feed/

# ── Janamat Pulse: civic domain ─────────────────────────────────────────────
# Nepali civic news RSS the agent reads (comma-separated). Free + keyless.
CIVIC_NEWS_FEEDS=https://english.onlinekhabar.com/feed,https://kathmandupost.com/rss,https://myrepublica.nagariknetwork.com/feed/,https://english.khabarhub.com/feed/
# Flag a project when avg public sentiment falls to/below this (-100..100).
CIVIC_FLAG_THRESHOLD=-20
# Min attributed items before a project's flag is meaningful.
CIVIC_MIN_SAMPLE=3

# ── On-chain anchoring (optional; set after `anchor deploy`) ─────────────────
# Deployed civic_record program id. Unset → agent runs fully off-chain and the
# opinion API returns the derived nullifier without broadcasting.
CIVIC_PROGRAM_ID=
# Relayer keypair that pays rent for on-chain opinions (citizens stay gas-free).
CIVIC_RELAYER_KEY=~/.config/solana/id.json
