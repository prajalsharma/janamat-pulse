# Janamat Pulse frontend — environment
# Copy to .env.local for local dev. In production these are set in the Vercel
# project settings (Settings → Environment Variables), not committed.

# --- Backend connection -----------------------------------------------------
# REST: next.config.mjs proxies /api/* to BACKEND_URL. Leave unset locally
# (defaults to http://localhost:4000). In Vercel, set it to the hosted backend:
#   BACKEND_URL=https://your-backend.onrender.com
# (BACKEND_URL is a server-side var, so it is NOT prefixed with NEXT_PUBLIC.)

# WebSocket: the browser connects here directly. Leave unset locally (defaults
# to ws://<host>:4000/ws). In Vercel, set it to the hosted backend over TLS:
#   NEXT_PUBLIC_WS_URL=wss://your-backend.onrender.com/ws
NEXT_PUBLIC_WS_URL=

# --- Privy auth -------------------------------------------------------------
# https://dashboard.privy.io. If unset, the app renders in read-only demo mode.
NEXT_PUBLIC_PRIVY_APP_ID=

# --- Solana -----------------------------------------------------------------
# RPC used to read the wallet balance and broadcast fund transfers. Devnet to
# match the backend cluster.
NEXT_PUBLIC_SOLANA_RPC=https://api.devnet.solana.com
