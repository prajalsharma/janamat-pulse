# SolVane frontend — local environment
# Copy to .env.local and fill in. The app runs WITHOUT these (read-only demo),
# but sign-in and "Fund the agent" require a Privy app ID.

# Privy app ID (https://dashboard.privy.io). If unset, the app renders in
# read-only demo mode: the terminal is fully viewable, but Start/Pause/Tick and
# funding are disabled and no login is offered.
NEXT_PUBLIC_PRIVY_APP_ID=

# Solana RPC used to read your wallet balance and broadcast fund transfers.
# Defaults to devnet to match the backend cluster. Only change if you point the
# backend at another cluster.
NEXT_PUBLIC_SOLANA_RPC=https://api.devnet.solana.com
